# Debian trixie matches the host, so artifacts built here link against the
# same libc / libstdc++ ABI the host will load them with.
FROM debian:trixie

# Engine-only build deps + dpkg-dev for assembling the .deb at the end.
# The WITH_GNUCASH=OFF / WITH_OFX=OFF / WITH_AQBANKING=OFF / WITH_PYTHON=OFF
# combo in build-in-container.sh drops libgtk-3-dev, libwebkit2gtk-4.1-dev,
# libofx-dev, and libaqbanking-dev from the transitive graph entirely.
RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential cmake ninja-build pkg-config swig gettext \
        libglib2.0-dev libxml2-dev libxslt1-dev xsltproc libicu-dev zlib1g-dev \
        libboost-dev libboost-date-time-dev libboost-filesystem-dev \
        libboost-locale-dev libboost-program-options-dev libboost-regex-dev \
        guile-3.0-dev libdbi-dev libdbd-sqlite3 libdbd-pgsql \
        libsecret-1-dev libgtest-dev libgmock-dev \
        dpkg-dev file binutils \
        git ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Bundle templates + the in-container build script. Baked in so the
# build is hermetic — no extra bind-mounts beyond /src and /out.
COPY debian-bundle/ /usr/local/share/libgnucash/
COPY build-in-container.sh /usr/local/bin/build-in-container
RUN chmod +x /usr/local/bin/build-in-container

WORKDIR /work

# Inputs (env, set by docker/libgnucash/build.sh):
#   GNUCASH_VERSION   e.g. 5.10  — used as the deb's Version: field.
#   ARCH              e.g. arm64 — dpkg architecture for the deb name.
# Bind-mounts (the wrapper provides):
#   /src   ro  gnucash source checkout
#   /out   rw  where the .deb lands on the host
ENTRYPOINT ["/usr/local/bin/build-in-container"]
